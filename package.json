{
  "name": "imgplex",
  "productName": "imgplex",
  "author": "psmyles",
  "description": "A GUI batch workflow builder that uses Imagemagick for processing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "imgplex": "./dist-electron/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.cli.config.ts && pkg dist-cli/cli-bundle.cjs --target node20-win-x64 --output dist-cli/cli-bundle.exe && electron-builder",
    "build:web": "vite build --config vite.web.config.ts",
    "preview": "vite preview",
    "link:cli": "npm link",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/patch-nsis.cjs",
    "prepare": "husky"
  },
  "pkg": {
    "targets": [
      "node20-win-x64"
    ]
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "husky": "^9.1.7",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.0"
  },
  "main": "dist-electron/main.js",
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@xyflow/svelte": "^1.5.1",
    "svelte": "^5.53.7"
  }
}
