{
  "id": "logic_comparison",
  "version": "1.0.0",
  "label": "Compare",
  "description": "Compare two values and output a boolean result",
  "category": "Logic",
  "inputs": [],
  "outputs": [],
  "executor": "logic_comparison",
  "params": [
    { "name": "a",        "label": "A",        "type": "any",  "default": null },
    { "name": "operator", "label": "Operator", "type": "enum", "widget": "dropdown", "default": "equal", "options": ["equal", "not equal", "greater than", "less than", "greater or equal", "less or equal"] },
    { "name": "b",        "label": "B",        "type": "any",  "default": null },
    { "name": "result",   "label": "Result",   "type": "bool",  "widget": "checkbox", "default": true, "readonly": true }
  ]
}
