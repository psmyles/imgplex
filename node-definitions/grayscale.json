{
  "id": "grayscale",
  "version": "1.0.0",
  "label": "Grayscale",
  "description": "Convert image to grayscale",
  "category": "Color",
  "icon": "circle-half",
  "inputs": [
    {
      "type": "image",
      "label": "Input"
    }
  ],
  "outputs": [
    {
      "type": "image",
      "label": "Output"
    }
  ],
  "params": [
    {
      "name": "method",
      "label": "Method",
      "type": "enum",
      "widget": "dropdown",
      "default": "Rec709Luminance",
      "options": [
        "Rec709Luminance",
        "Rec601Luminance",
        "Average",
        "RMS",
        "Brightness"
      ]
    }
  ],
  "command_template": "-grayscale {{method}}"
}
