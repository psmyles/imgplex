{
  "id": "gate",
  "version": "1.0.0",
  "label": "Gate",
  "description": "Passes the image to output only when the condition is true. In batch mode, images that fail the condition are not written to the output folder.",
  "category": "Logic",
  "inputs": [
    {
      "type": "image",
      "label": "Input"
    }
  ],
  "outputs": [
    {
      "type": "image",
      "label": "Output"
    }
  ],
  "executor": "gate",
  "params": [
    {
      "name": "condition",
      "label": "Condition",
      "type": "bool",
      "widget": "checkbox",
      "default": true
    }
  ]
}
