{
  "id": "blur",
  "version": "1.0.0",
  "label": "Blur",
  "description": "Apply Gaussian blur",
  "category": "Filters",
  "icon": "droplets",
  "inputs": [
    {
      "type": "image",
      "label": "Input"
    }
  ],
  "outputs": [
    {
      "type": "image",
      "label": "Output"
    }
  ],
  "params": [
    {
      "name": "sigma",
      "label": "Sigma",
      "type": "float",
      "widget": "slider",
      "default": 2,
      "min": 0.1,
      "max": 50,
      "step": 0.1
    }
  ],
  "command_template": "-blur 0x{{sigma}}"
}
