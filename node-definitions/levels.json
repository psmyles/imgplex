{
  "id": "levels",
  "version": "1.0.0",
  "label": "Levels",
  "description": "Adjust black point, white point, and gamma",
  "category": "Color",
  "icon": "sliders",
  "inputs": [
    {
      "type": "image",
      "label": "Input"
    }
  ],
  "outputs": [
    {
      "type": "image",
      "label": "Output"
    }
  ],
  "params": [
    {
      "name": "black_point",
      "label": "Black Point",
      "type": "float",
      "widget": "slider",
      "default": 0,
      "min": 0,
      "max": 99,
      "step": 0.5
    },
    {
      "name": "white_point",
      "label": "White Point",
      "type": "float",
      "widget": "slider",
      "default": 100,
      "min": 1,
      "max": 100,
      "step": 0.5
    },
    {
      "name": "gamma",
      "label": "Gamma",
      "type": "float",
      "widget": "slider",
      "default": 1,
      "min": 0.1,
      "max": 10,
      "step": 0.1
    }
  ],
  "command_template": "-level {{black_point}}%,{{white_point}}%,{{gamma}}"
}
