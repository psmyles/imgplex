{
  "id": "split_vec",
  "version": "1.0.0",
  "label": "Split",
  "description": "Breaks a vector or color into X, Y, Z, W float components",
  "category": "Utility",
  "inputs": [],
  "outputs": [],
  "executor": "split_vec",
  "params": [
    { "name": "vec", "label": "Vector", "type": "numeric", "widget": "number", "default": 0 },
    { "name": "x",   "label": "X",     "type": "float",   "widget": "number", "default": 0, "readonly": true },
    { "name": "y",   "label": "Y",     "type": "float",   "widget": "number", "default": 0, "readonly": true },
    { "name": "z",   "label": "Z",     "type": "float",   "widget": "number", "default": 0, "readonly": true },
    { "name": "w",   "label": "W",     "type": "float",   "widget": "number", "default": 0, "readonly": true }
  ]
}
