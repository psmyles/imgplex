{
  "id": "math_lerp",
  "version": "1.0.0",
  "label": "Lerp",
  "description": "Linear interpolation: A + (B − A) × T",
  "category": "Math",
  "inputs": [],
  "outputs": [],
  "executor": "math_lerp",
  "params": [
    { "name": "a",      "label": "A",      "type": "numeric", "widget": "number", "default": 0 },
    { "name": "b",      "label": "B",      "type": "numeric", "widget": "number", "default": 1 },
    { "name": "t",      "label": "T",      "type": "float",   "widget": "slider", "default": 0.5, "min": 0, "max": 1, "step": 0.01 },
    { "name": "result", "label": "Result", "type": "numeric", "widget": "number", "default": 0.5, "readonly": true }
  ]
}
